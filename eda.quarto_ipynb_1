    "#| label: correlaciones\n",
    "# Crear variables numéricas derivadas para correlacionar\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# --- PASO 1: Seleccionar delitos relevantes para la matriz ---\n",
    "# Para no saturar la matriz, elige los delitos con mayor incidencia\n",
    "# o los que teóricamente podrían estar relacionados.\n",
    "\n",
    "delitos_interes = [\n",
    "    'Robo a casa habitación', \n",
    "    'Robo a negocio', \n",
    "    'Robo de vehículo automotor',\n",
    "    'Robo a transeúnte en vía pública',\n",
    "    'Fraude', \n",
    "    'Homicidio doloso', \n",
    "    'Lesiones dolosas', \n",
    "    'Violencia familiar',\n",
    "    'Abuso sexual',\n",
    "    'Extorsión',\n",
    "    'Daño a la propiedad'\n",
    "]\n",
    "\n",
    "# Filtrar el dataframe solo para esos delitos\n",
    "df_filtrado = df[df['tipo_delito'].isin(delitos_interes)].copy()\n",
    "\n",
    "# --- PASO 2: Agrupar y pivotear ---\n",
    "# Agrupamos por entidad y tipo de delito, sumando la incidencia\n",
    "# (podrías agrupar también por año/mes si quisieras series de tiempo)\n",
    "\n",
    "# Agrupar por entidad, año y tipo de delito\n",
    "tabla_anual = df_filtrado.groupby(\n",
    "    ['entidad_federativa', 'anio', 'tipo_delito']\n",
    ")['incidencia_delictiva'].sum().reset_index()\n",
    "\n",
    "tabla_pivot_anual = tabla_anual.pivot(\n",
